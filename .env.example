# Required for Douban scraping (get from browser cookies)
DOUBAN_COOKIE=

# Required for TMDB API (get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Required for Trakt API (get from https://trakt.tv/oauth/applications)
TRAKT_API_CLIENT_ID=
TRAKT_APP_NAME=PT-Gen-Next

# Optional: QQ Music cookie for album details
QQ_COOKIE=

# Optional: API key to protect the endpoint
API_KEY=

# Optional: Custom author name
AUTHOR=Hares

# Set to "false" to disable caching
ENABLED_CACHE=true
